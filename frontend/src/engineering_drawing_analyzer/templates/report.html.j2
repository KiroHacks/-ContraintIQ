<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Engineering Drawing Verification Report — {{ report.drawing_id }}</title>
  <style>
    /* ------------------------------------------------------------------ */
    /* Reset & base                                                         */
    /* ------------------------------------------------------------------ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: "Segoe UI", Arial, sans-serif;
      font-size: 14px;
      line-height: 1.5;
      color: #1a1a2e;
      background: #f5f7fa;
      padding: 24px;
    }

    /* ------------------------------------------------------------------ */
    /* Layout                                                               */
    /* ------------------------------------------------------------------ */
    .container {
      max-width: 960px;
      margin: 0 auto;
      background: #ffffff;
      border-radius: 8px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
      overflow: hidden;
    }

    /* ------------------------------------------------------------------ */
    /* Header                                                               */
    /* ------------------------------------------------------------------ */
    .header {
      background: #1a1a2e;
      color: #ffffff;
      padding: 28px 32px;
    }

    .header h1 {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: 0.5px;
      margin-bottom: 4px;
    }

    .header .subtitle {
      font-size: 13px;
      color: #a0aec0;
    }

    /* ------------------------------------------------------------------ */
    /* Status banner                                                        */
    /* ------------------------------------------------------------------ */
    .status-banner {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 16px 32px;
      font-size: 16px;
      font-weight: 600;
    }

    .status-banner.pass {
      background: #f0fff4;
      border-left: 6px solid #38a169;
      color: #276749;
    }

    .status-banner.fail {
      background: #fff5f5;
      border-left: 6px solid #e53e3e;
      color: #9b2c2c;
    }

    .status-icon {
      font-size: 22px;
    }

    /* ------------------------------------------------------------------ */
    /* Summary section                                                      */
    /* ------------------------------------------------------------------ */
    .section {
      padding: 24px 32px;
      border-bottom: 1px solid #e2e8f0;
    }

    .section:last-child {
      border-bottom: none;
    }

    .section-title {
      font-size: 15px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: #4a5568;
      margin-bottom: 16px;
    }

    /* ------------------------------------------------------------------ */
    /* Metadata grid                                                        */
    /* ------------------------------------------------------------------ */
    .meta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 12px;
    }

    .meta-item {
      background: #f7fafc;
      border: 1px solid #e2e8f0;
      border-radius: 6px;
      padding: 12px 16px;
    }

    .meta-label {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      color: #718096;
      margin-bottom: 4px;
    }

    .meta-value {
      font-size: 14px;
      font-weight: 600;
      color: #2d3748;
      word-break: break-all;
    }

    /* ------------------------------------------------------------------ */
    /* Issue count cards                                                    */
    /* ------------------------------------------------------------------ */
    .count-cards {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }

    .count-card {
      flex: 1;
      min-width: 120px;
      border-radius: 8px;
      padding: 16px 20px;
      text-align: center;
    }

    .count-card.critical {
      background: #fff5f5;
      border: 1px solid #feb2b2;
    }

    .count-card.warning {
      background: #fffaf0;
      border: 1px solid #fbd38d;
    }

    .count-card.info {
      background: #ebf8ff;
      border: 1px solid #90cdf4;
    }

    .count-number {
      font-size: 32px;
      font-weight: 800;
      line-height: 1;
      margin-bottom: 4px;
    }

    .count-card.critical .count-number { color: #c53030; }
    .count-card.warning  .count-number { color: #c05621; }
    .count-card.info     .count-number { color: #2b6cb0; }

    .count-label {
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.6px;
    }

    .count-card.critical .count-label { color: #9b2c2c; }
    .count-card.warning  .count-label { color: #7b341e; }
    .count-card.info     .count-label { color: #2c5282; }

    /* ------------------------------------------------------------------ */
    /* Issues table                                                         */
    /* ------------------------------------------------------------------ */
    .issues-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }

    .issues-table thead tr {
      background: #edf2f7;
    }

    .issues-table th {
      text-align: left;
      padding: 10px 12px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      color: #4a5568;
      border-bottom: 2px solid #cbd5e0;
    }

    .issues-table td {
      padding: 10px 12px;
      border-bottom: 1px solid #e2e8f0;
      vertical-align: top;
    }

    .issues-table tbody tr:hover {
      background: #f7fafc;
    }

    /* ------------------------------------------------------------------ */
    /* Severity badges                                                      */
    /* ------------------------------------------------------------------ */
    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 12px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.4px;
      white-space: nowrap;
    }

    .badge-critical {
      background: #fed7d7;
      color: #9b2c2c;
    }

    .badge-warning {
      background: #feebc8;
      color: #7b341e;
    }

    .badge-info {
      background: #bee3f8;
      color: #2c5282;
    }

    /* ------------------------------------------------------------------ */
    /* Systemic patterns                                                    */
    /* ------------------------------------------------------------------ */
    .pattern-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .pattern-item {
      background: #fffaf0;
      border: 1px solid #fbd38d;
      border-left: 4px solid #ed8936;
      border-radius: 4px;
      padding: 10px 14px;
      font-size: 13px;
      color: #744210;
    }

    /* ------------------------------------------------------------------ */
    /* Empty state                                                          */
    /* ------------------------------------------------------------------ */
    .empty-state {
      text-align: center;
      padding: 32px;
      color: #718096;
      font-size: 14px;
    }

    .empty-state .icon {
      font-size: 36px;
      margin-bottom: 8px;
    }

    /* ------------------------------------------------------------------ */
    /* Footer                                                               */
    /* ------------------------------------------------------------------ */
    .footer {
      background: #f7fafc;
      padding: 16px 32px;
      font-size: 12px;
      color: #a0aec0;
      text-align: center;
      border-top: 1px solid #e2e8f0;
    }

    /* ------------------------------------------------------------------ */
    /* Print / PDF overrides                                                */
    /* ------------------------------------------------------------------ */
    @media print {
      body { background: #fff; padding: 0; }
      .container { box-shadow: none; border-radius: 0; }
    }
  </style>
</head>
<body>
  <div class="container">

    <!-- Header -->
    <div class="header">
      <h1>Engineering Drawing Verification Report</h1>
      <div class="subtitle">Generated by Engineering Drawing Analyzer</div>
    </div>

    <!-- Status banner -->
    {% if report.overall_status == "Pass" %}
    <div class="status-banner pass">
      <span class="status-icon">✔</span>
      <span>PASS — Drawing is fully dimensioned, fully constrained, and ready for manufacturing.</span>
    </div>
    {% else %}
    <div class="status-banner fail">
      <span class="status-icon">✖</span>
      <span>FAIL — Issues were found that must be resolved before manufacturing.</span>
    </div>
    {% endif %}

    <!-- Metadata -->
    <div class="section">
      <div class="section-title">Report Details</div>
      <div class="meta-grid">
        <div class="meta-item">
          <div class="meta-label">Drawing ID</div>
          <div class="meta-value">{{ report.drawing_id }}</div>
        </div>
        <div class="meta-item">
          <div class="meta-label">Analysis Timestamp</div>
          <div class="meta-value">{{ report.analysis_timestamp }}</div>
        </div>
        <div class="meta-item">
          <div class="meta-label">Overall Status</div>
          <div class="meta-value">{{ report.overall_status }}</div>
        </div>
        <div class="meta-item">
          <div class="meta-label">Total Issues</div>
          <div class="meta-value">{{ report.issues | length }}</div>
        </div>
      </div>
    </div>

    <!-- Issue counts -->
    <div class="section">
      <div class="section-title">Issue Summary</div>
      <div class="count-cards">
        <div class="count-card critical">
          <div class="count-number">{{ report.issue_counts.get("Critical", 0) }}</div>
          <div class="count-label">Critical</div>
        </div>
        <div class="count-card warning">
          <div class="count-number">{{ report.issue_counts.get("Warning", 0) }}</div>
          <div class="count-label">Warning</div>
        </div>
        <div class="count-card info">
          <div class="count-number">{{ report.issue_counts.get("Info", 0) }}</div>
          <div class="count-label">Info</div>
        </div>
      </div>
    </div>

    <!-- Systemic patterns -->
    {% if report.systemic_patterns %}
    <div class="section">
      <div class="section-title">Systemic Patterns</div>
      <ul class="pattern-list">
        {% for pattern in report.systemic_patterns %}
        <li class="pattern-item">{{ pattern }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    <!-- Issues list -->
    <div class="section">
      <div class="section-title">Issues ({{ report.issues | length }})</div>
      {% if report.issues %}
      <table class="issues-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Severity</th>
            <th>Type</th>
            <th>Description</th>
            <th>Location</th>
            <th>Corrective Action</th>
            <th>Standard Ref.</th>
          </tr>
        </thead>
        <tbody>
          {% for issue in report.issues %}
          <tr>
            <td>{{ loop.index }}</td>
            <td>
              {% set sev = issue.severity.value if issue.severity is not string else issue.severity %}
              {% if sev == "Critical" %}
                <span class="badge badge-critical">Critical</span>
              {% elif sev == "Warning" %}
                <span class="badge badge-warning">Warning</span>
              {% else %}
                <span class="badge badge-info">Info</span>
              {% endif %}
            </td>
            <td><code>{{ issue.issue_type }}</code></td>
            <td>{{ issue.description }}</td>
            <td>
              <strong>{{ issue.location.view_name }}</strong>
              {% if issue.location.coordinates %}
                <br/><small>({{ issue.location.coordinates.x }}, {{ issue.location.coordinates.y }})</small>
              {% endif %}
              {% if issue.location.label %}
                <br/><small>{{ issue.location.label }}</small>
              {% endif %}
            </td>
            <td>{{ issue.corrective_action or "—" }}</td>
            <td>{{ issue.standard_reference or "—" }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <div class="empty-state">
        <div class="icon">✔</div>
        <div>No issues found. The drawing passed all verification checks.</div>
      </div>
      {% endif %}
    </div>

    <!-- Footer -->
    <div class="footer">
      Engineering Drawing Analyzer &mdash; Automated ANSI/ASME Y14.5 Verification
    </div>

  </div>
</body>
</html>
